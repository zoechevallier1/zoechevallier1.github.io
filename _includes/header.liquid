<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      {% assign current_lang = page.lang | default: site.lang | split: '-' | first %}
      {% assign home_url = '/' %}
      {% for p in site.pages %}
        {% assign p_lang = p.lang | default: site.lang | split: '-' | first %}
        {% if p.ref == 'about' and p_lang == current_lang %}
          {% assign home_url = p.url %}
        {% endif %}
      {% endfor %}
      {% if page.permalink != '/' %}
        <a class="navbar-brand title font-weight-lighter" href="{{ home_url | relative_url }}">
          {% if site.title == 'blank' %}
            {% if site.first_name %}
              <span class="font-weight-bold">
                {{- site.first_name -}}
              </span>
            {% endif %}
            {% if site.middle_name %}
              {{- site.middle_name -}}
            {% endif %}
            {% if site.last_name %}
              {{- site.last_name -}}
            {% endif %}
          {% else %}
            {{- site.title -}}
          {% endif %}
        </a>
      {% elsif site.enable_navbar_social %}
        <!-- Social Icons -->
        <div class="navbar-brand social">{% social_links %}</div>
      {% endif %}
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% assign about_title = null %}
          {% assign about_url = home_url %}
          {% for p in site.pages %}
            {% assign p_lang = p.lang | default: site.lang | split: '-' | first %}
            {% if p.ref == 'about' and p_lang == current_lang %}
              {% assign about_title = p.title %}
              {% assign about_url = p.url %}
            {% endif %}
          {% endfor %}
          {% if about_title == null %}
            {% for p in site.pages %}
              {% if p.permalink == '/' %}
                {% assign about_title = p.title %}
                {% assign about_url = p.url %}
              {% endif %}
            {% endfor %}
          {% endif %}

          <!-- About -->
          <li class="nav-item {% if page.ref == 'about' or page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ about_url | relative_url }}">
              {{- about_title }}
              {% if page.ref == 'about' or page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% assign p_lang = p.lang | default: site.lang | split: '-' | first %}
            {% if p.nav and p.autogen == null and p_lang == current_lang and p.ref != 'about' %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a
                          class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                          href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                        >
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                  {%- if p.permalink contains '://' -%}
                    {%- assign url = p.permalink -%}
                  {%- elsif p.permalink contains '/blog/' -%}
                    {%- assign url = '/blog/' -%}
                  {%- else -%}
                    {%- assign url = p.url -%}
                  {%- endif %}
                  <a class="nav-link" href="{{ url | relative_url }}">
                    {{- p.title }}
                    {% if page.url contains p.url %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}

          {% assign target_lang = 'fr' %}
          {% if current_lang == 'fr' %}
            {% assign target_lang = 'en' %}
          {% endif %}
          {% assign switch_url = null %}
          {% if page.ref %}
            {% for p in site.pages %}
              {% assign p_lang = p.lang | default: site.lang | split: '-' | first %}
              {% if p.ref == page.ref and p_lang == target_lang %}
                {% assign switch_url = p.url %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% if switch_url == null %}
            {% if current_lang == 'fr' %}
              {% if page.url == '/fr/' %}
                {% assign switch_url = '/' %}
              {% else %}
                {% assign switch_url = page.url | remove_first: '/fr' %}
              {% endif %}
            {% else %}
              {% if page.url == '/' %}
                {% assign switch_url = '/fr/' %}
              {% else %}
                {% assign switch_url = '/fr' | append: page.url %}
              {% endif %}
            {% endif %}
          {% endif %}
          <li class="nav-item">
            <a class="nav-link" href="{{ switch_url | relative_url }}">{{ target_lang | upcase }}</a>
          </li>

          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="fa-solid fa-magnifying-glass"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Toogle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
