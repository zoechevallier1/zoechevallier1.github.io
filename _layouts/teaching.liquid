---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {{ content }}
    {% assign current_lang = page.lang | default: site.lang | split: '-' | first %}
    {% assign teaching_sections = site.data.teaching %}
    {% if current_lang == 'fr' and site.data.teaching_fr %}
      {% assign teaching_sections = site.data.teaching_fr %}
    {% endif %}
    {% if teaching_sections and teaching_sections.size > 0 %}
      <div class="row teaching-layout mt-4">
        <aside class="col-lg-3 teaching-sidebar-wrap">
          <nav class="teaching-sidebar" aria-label="Teaching lesson titles">
            <h2 class="teaching-sidebar-title">
              {% if current_lang == 'fr' %}Cours{% else %}Lessons{% endif %}
            </h2>
            <ul class="list-unstyled mb-0">
              {% for section in teaching_sections %}
                <li>
                  <a class="teaching-sidebar-link" href="#{{ section.title | slugify }}">{{ section.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        </aside>
        <div class="col-lg-9">
          {% include data_sections.liquid sections=teaching_sections variant='teaching' %}
        </div>
      </div>
    {% else %}
      {% include data_sections.liquid sections=teaching_sections variant='teaching' %}
    {% endif %}
  </article>

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
